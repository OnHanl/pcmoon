# Заполните и разместите на сервере рядом с docker-compose.yml как
# deploy/pcservice.env — docker-compose подхватит его через env_file.
#
# ВАЖНО: этот файл содержит секреты — никогда не коммитьте заполненную
# версию в git (он уже добавлен в .dockerignore, но не забудьте и про
# .gitignore, если используете git).

# Сгенерировать: python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=замените-на-случайную-строку

DJANGO_DEBUG=False

# Через запятую, без пробелов, без http:// — домен и/или IP сервера
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Через запятую, ПОЛНЫЕ url с https://
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Пока сертификата ещё нет (используется deploy/nginx/app.conf, ЭТАП 1),
# держите False, иначе Django будет редиректить на https, которого ещё нет.
# После перехода на app-ssl.conf — включите True.
DJANGO_SECURE_SSL_REDIRECT=False
